{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",       
    "moduleResolution": "Node",
    "esModuleInterop": true,    
    "outDir": "lib",            
    "rootDir": "src",          
    "strict": true,
    "declaration": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "**/*.test.ts"]
}